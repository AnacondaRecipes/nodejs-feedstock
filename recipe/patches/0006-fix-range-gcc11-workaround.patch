 namespace node {
 
+// GCC 11 libstdc++ lacks contiguous storage for ranges::split_view parts,
+// so they don't have .data()/.size(). Provide a safe helper to copy a range
+// of chars into a std::string.
+template <typename Range>
+static inline std::string RangeToString(const Range& r) {
+  std::string out;
+  for (auto ch : r) out.push_back(static_cast<char>(ch));
+  return out;
+}
